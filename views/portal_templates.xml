<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="vendor_portal_navbar" inherit_id="portal.portal_layout">
        <xpath expr="//div[@id='wrap']" position="before">
            <style>
                .o_portal_category_selectable, .breadcrumb, .o_portal_submenu { 
                    display: none !important; 
                }
            </style>
            <nav class="navbar navbar-expand-lg shadow-sm sticky-top" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-bottom: 2px solid #00008B;">
                <div class="container-fluid px-4">
                    <a class="navbar-brand fw-bold" href="/my/home" style="color: #00008B;">
                        <i class="fa fa-th-large me-2"></i>Vendor Hub
                    </a>
                    <div class="collapse navbar-collapse" id="vendorNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item"><a class="nav-link fw-semibold" href="/my/home">Home</a></li>
                            <li class="nav-item"><a class="nav-link fw-semibold" href="/my/orders">Sales Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link fw-semibold" href="/my/tickets">Support</a></li>
                        </ul>
                        <div class="d-flex align-items-center gap-2">
                            <a href="/my/sales-charts" class="btn btn-sm text-white" style="background-color: #00008B; border-radius: 8px;">
                                <i class="fa fa-bar-chart me-1"></i> Sales Charts
                            </a>
                            <a href="/my/inventory-details" class="btn btn-sm text-white" style="background-color: #00008B; border-radius: 8px;">
                                <i class="fa fa-pie-chart me-1"></i> More Details
                            </a>
                        </div>
                    </div>
                </div>
            </nav>
        </xpath>
    </template>

    <template id="vendor_sales_history_page" name="Vendor Sales History">
    <t t-call="portal.portal_layout">
        <style>
            /* Modern Card Styling */
            .kpi-card { 
                transition: all 0.3s ease; 
                border-radius: 12px !important;
                background: #ffffff;
            }
            .kpi-card:hover { 
                transform: translateY(-4px); 
                box-shadow: 0 12px 24px rgba(0,0,0,0.08) !important; 
            }
            .icon-box {
                width: 50px;
                height: 50px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 10px;
            }
            /* Table Row Highlighting */
            .row-critical { background-color: #fff5f5 !important; }
            .badge-pill-custom {
                padding: 0.5em 1em;
                border-radius: 50px;
                font-size: 0.75rem;
                font-weight: 600;
            }
        </style>

        <div id="wrap" class="container mt-4">
            <div class="row align-items-center mb-4">
                <div class="col">
                    <h3 class="fw-bold mb-0" style="color: #00008B;">Good Morning, <t t-esc="request.env.user.name"/></h3>
                    <p class="text-muted small">Here is what’s happening with your store today.</p>
                </div>
                <div class="col-auto">
                    <div class="text-end text-muted small">
                        <i class="fa fa-clock-o me-1"></i> <t t-esc="last_updated" t-options='{"widget": "datetime"}'/>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm kpi-card p-2">
                        <div class="card-body d-flex align-items-center">
                            <div class="icon-box bg-primary-light me-3" style="background: #eef2ff;">
                                <i class="fa fa-line-chart" style="color: #00008B; font-size: 1.2rem;"></i>
                            </div>
                            <div>
                                <div class="text-muted small fw-bold">REVENUE</div>
                                <h4 class="mb-0 fw-bold"><t t-esc="total_revenue" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></h4>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm kpi-card p-2">
                        <div class="card-body d-flex align-items-center">
                            <div class="icon-box me-3" style="background: #ecfeff;">
                                <i class="fa fa-shopping-cart" style="color: #0891b2; font-size: 1.2rem;"></i>
                            </div>
                            <div>
                                <div class="text-muted small fw-bold">UNITS SOLD</div>
                                <h4 class="mb-0 fw-bold"><t t-esc="total_units_sold or 0"/></h4>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm kpi-card p-2">
                        <div class="card-body d-flex align-items-center">
                            <div class="icon-box me-3" style="background: #f0fdf4;">
                                <i class="fa fa-archive" style="color: #16a34a; font-size: 1.2rem;"></i>
                            </div>
                            <div>
                                <div class="text-muted small fw-bold">PRODUCTS</div>
                                <h4 class="mb-0 fw-bold"><t t-esc="total_products_count or 0"/></h4>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm kpi-card p-2">
                        <div class="card-body d-flex align-items-center">
                            <div class="icon-box me-3" style="background: #fef2f2;">
                                <i class="fa fa-exclamation-triangle text-danger" style="font-size: 1.2rem;"></i>
                            </div>
                            <div>
                                <div class="text-muted small fw-bold">STOCK ALERTS</div>
                                <h4 class="mb-0 fw-bold text-danger"><t t-esc="low_stock_count or 0"/></h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                <div class="card-body p-0">
                    <table class="table mb-0 align-middle">
                        <thead class="bg-light text-muted small text-uppercase fw-bold">
                            <tr>
                                <th class="ps-4 py-3">Product Description</th>
                                <th class="py-3">Category</th>
                                <th class="py-3 text-center">Stock Level</th>
                                <th class="pe-4 py-3 text-end">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="vendor_products" t-as="product">
                                <tr t-att-class="'row-critical' if product.qty_available == 0 else ''">
                                    <td class="ps-4 py-4">
                                        <div class="fw-bold" style="color: #00008B;"><t t-esc="product.name"/></div>
                                        <div class="text-muted x-small">SKU: <t t-esc="product.default_code or 'N/A'"/></div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border"><t t-esc="product.categ_id.name"/></span>
                                    </td>
                                    <td class="text-center">
                                        <div t-attf-class="fw-bold #{'text-danger' if product.qty_available == 0 else 'text-dark'}">
                                            <t t-esc="int(product.qty_available)"/>
                                        </div>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <t t-if="product.qty_available == 0">
                                            <span class="badge bg-danger badge-pill-custom">Out of Stock</span>
                                        </t>
                                        <t t-elif="product.qty_available &lt; 10">
                                            <span class="badge bg-warning text-dark badge-pill-custom">Low Stock</span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge bg-success badge-pill-custom">Healthy</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </t>
</template>

    <template id="portal_my_home_vendor_exclusive" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <div class="container mt-4 mb-2">
                <div class="card shadow-sm border-0 p-4 text-center" style="border-radius: 15px; background: #f8f9fa;">
                    <h4 class="fw-bold mb-3" style="color: #00008B;">Vendor Portal</h4>
                    <p class="text-muted mb-4">Manage your performance and inventory status.</p>
                    <div>
                        <a href="/my/orders" class="btn text-white shadow" style="background-color: #00008B !important; border-radius: 10px; padding: 15px 40px; font-size: 1.1rem;">
                            <i class="fa fa-line-chart me-2"></i><strong>Open Sales Dashboard</strong>
                        </a>
                    </div>
                </div>
            </div>
            <a href="/my/support" class="vendor-help-fab" title="Contact Support">
                <i class="fa fa-life-ring"></i><span class="ms-2">Support</span>
            </a>
            <style>
                .vendor-help-fab { position: fixed; bottom: 30px; left: 30px; color: #00008B !important; border: 2px solid #00008B; padding: 12px 25px; border-radius: 50px; display: flex; align-items: center; justify-content: center; text-decoration: none !important; z-index: 9999; transition: all 0.3s ease; font-weight: bold; backdrop-filter: blur(4px); }
                .o_portal_docs, .o_portal_my_home .row:not(.justify-content-center), #portal_client_category, [href="/my/invoices"], [href="/my/quotes"] { display: none !important; }
            </style>
        </xpath>
    </template>

    <template id="inventory_details_page" name="Inventory Details">
        <t t-call="portal.portal_layout">
            <div class="container mt-4 mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold" style="color: #00008B;">Full Inventory Report</h2>
                    <a href="/my/orders" class="btn btn-outline-secondary">
                        <i class="fa fa-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>

                <div class="row mb-5 g-4">
                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 12px;">
                            <h5 class="fw-bold text-center mb-3" style="color: #00008B;">Stock by Product Line</h5>
                            <canvas id="inventoryPieChart" style="max-height: 280px;"></canvas>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 12px;">
                            <h5 class="fw-bold text-center mb-3" style="color: #00008B;">Stock by Category</h5>
                            <canvas id="categoryPieChart" style="max-height: 280px;"></canvas>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0" style="border-radius: 12px;">
                    <div class="card-header bg-white border-0 pt-3">
                        <h5 class="fw-bold mb-0">Detailed Inventory List</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light text-muted small text-uppercase">
                                <tr>
                                    <th>SKU</th>
                                    <th>Product Name</th>
                                    <th>Category</th>
                                    <th class="text-end">On Hand</th>
                                    <th class="text-end">Forecasted</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="vendor_products" t-as="p">
                                    <tr>
                                        <td class="fw-bold" style="color: #00008B;"><t t-esc="p.default_code or 'N/A'"/></td>
                                        <td><t t-esc="p.name"/></td>
                                        <td class="text-muted"><t t-esc="p.categ_id.name"/></td>
                                        <td class="text-end fw-bold">
                                            <span t-attf-class="{{'text-danger' if p.qty_available &lt; 5 else 'text-dark'}}" t-esc="int(p.qty_available)"/>
                                        </td>
                                        <td class="text-end text-muted small"><t t-esc="int(p.virtual_available)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
                <script type="text/javascript">
                // <![CDATA[
                    document.addEventListener('DOMContentLoaded', function() {
                        var bluePalette = ['#00008B', '#1E90FF', '#4682B4', '#87CEEB', '#B0C4DE', '#6495ED'];

                        var productCtx = document.getElementById('inventoryPieChart').getContext('2d');
                        var productData = ]]> <t t-raw="inventory_chart_data"/> <![CDATA[;

                        if (productData && productData.datasets && productData.datasets[0]) {
                            productData.datasets[0].backgroundColor = bluePalette;
                        }

                        new Chart(productCtx, {
                            type: 'pie',
                            data: productData,
                            options: {
                                responsive: true,
                                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } }
                            }
                        });

                        var categCtx = document.getElementById('categoryPieChart').getContext('2d');
                        var categories = {};
                        ]]>
                        <t t-foreach="vendor_products" t-as="p">
                            var catName = "<t t-esc='p.categ_id.name'/>";
                            var qty = <t t-esc='p.qty_available'/>;
                            categories[catName] = (categories[catName] || 0) + qty;
                        </t>
                        <![CDATA[

                        new Chart(categCtx, {
                            type: 'doughnut',
                            data: {
                                labels: Object.keys(categories),
                                datasets: [{
                                    data: Object.values(categories),
                                    backgroundColor: bluePalette
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } }
                            }
                        });
                    });
                // ]]>
                </script>
            </div>
        </t>
    </template>

    <template id="vendor_sales_charts_page" name="Vendor Sales Charts">
        <t t-call="portal.portal_layout">
            <div class="container mt-4 mb-5">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold" style="color: #00008B;">Sales Charts &amp; History</h2>
                        <p class="text-muted mb-0">Visual breakdown and full sales history.</p>
                    </div>
                    <a href="/my/orders" class="btn btn-outline-secondary" style="border-radius: 8px;">
                        <i class="fa fa-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>

                <div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-white h-100 p-4" style="background-color: #00008B; border-radius: 12px;">
            <small class="text-uppercase opacity-75 fw-bold">Total Units Sold</small>
            <h1 class="fw-bold mb-0" style="font-size: 3rem;"><t t-esc="total_units_sold"/></h1>
            <small class="opacity-75">Confirmed Orders</small>
        </div>
    </div>
    </div>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0 p-3" style="border-radius: 12px;">
            <h5 class="fw-bold mb-3" style="color: #00008B;">
                <i class="fa fa-line-chart me-2"></i>Monthly Sales Trend
            </h5>
            <canvas id="monthlyTrendChart" style="max-height: 300px; width: 100%;"></canvas>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-7">
        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 12px;">
            <h5 class="fw-bold mb-3" style="color: #00008B;">
                <i class="fa fa-bar-chart me-2"></i>Top Products
            </h5>
            <canvas id="topProductsChart" style="max-height: 280px;"></canvas>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 12px;">
            <h5 class="fw-bold mb-3" style="color: #00008B;">
                <i class="fa fa-pie-chart me-2"></i>Sales by Customer
            </h5>
            <canvas id="customerPieChart" style="max-height: 280px;"></canvas>
        </div>
    </div>
</div>

                <div class="card shadow-sm border-0" style="border-radius: 12px;">
                    <div class="card-header bg-white border-0 pt-3 pb-2">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <span class="fw-bold">Recent Sales History</span>
                            <form method="get" class="d-flex align-items-center flex-wrap gap-2">
                                <select name="partner_id" class="form-select form-select-sm shadow-sm" style="max-width: 180px;">
                                    <option value="">All Customers</option>
                                    <t t-foreach="customers" t-as="customer">
                                        <option t-att-value="customer['id']" t-att-selected="customer['id'] == current_partner_id">
                                            <t t-esc="customer['display_name']"/>
                                        </option>
                                    </t>
                                </select>

                                <select name="product_id" class="form-select form-select-sm shadow-sm" style="max-width: 180px;">
                                    <option value="">All Products</option>
                                    <t t-foreach="filter_products" t-as="fp">
                                        <option t-att-value="fp.id" t-att-selected="fp.id == current_product_id">
                                            <t t-esc="fp.name"/>
                                        </option>
                                    </t>
                                </select>

                                <button type="submit" class="btn btn-sm text-white" style="background-color: #00008B; border-radius: 8px;">
                                    <i class="fa fa-filter me-1"></i> Filter
                                </button>
                                <a href="/my/sales-charts" class="btn btn-sm btn-outline-secondary" style="border-radius: 8px;">
                                    <i class="fa fa-times"></i>
                                </a>
                            </form>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 text-nowrap">
                            <thead class="bg-light text-muted small text-uppercase">
                                <tr>
                                    <th style="width: 30px;"></th>
                                    <th>Date</th>
                                    <th>Order #</th>
                                    <th>Customer</th>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="grouped_sales" t-as="group">
                                    <tr class="table-light customer-group-header"
                                        style="cursor: pointer; border-left: 3px solid #00008B;"
                                        t-att-data-target="'group-' + str(group['partner_id'])">
                                        <td class="text-center">
                                            <i class="fa fa-chevron-right toggle-icon"
                                               style="color: #00008B; font-size: 0.75rem; transition: transform 0.2s;"></i>
                                        </td>
                                        <td colspan="2">
                                            <span class="fw-bold" style="color: #00008B;">
                                                <t t-esc="group['partner_name']"/>
                                            </span>
                                            <span class="text-muted small ms-2">
                                                (<t t-esc="group['order_count']"/> orders)
                                            </span>
                                        </td>
                                        <td></td>
                                        <td></td>
                                        <td class="text-center fw-bold"><t t-esc="group['total_qty']"/></td>
                                        <td class="text-end fw-bold" style="color: #00008B;">
                                            $<t t-esc="'%.2f' % group['total_amount']"/>
                                        </td>
                                    </tr>
                                    <t t-foreach="group['lines']" t-as="line">
                                        <tr t-attf-class="group-row group-{{ group['partner_id'] }}" style="display: none;">
                                            <td></td>
                                            <td class="ps-3 text-muted small">
                                                <span t-field="line.create_date" t-options='{"widget": "date"}'/>
                                            </td>
                                            <td><t t-esc="line.order_id.name"/></td>
                                            <td class="small text-muted"><t t-esc="line.order_id.partner_id.name"/></td>
                                            <td class="fw-bold"><t t-esc="line.product_id.name"/></td>
                                            <td class="text-center"><t t-esc="int(line.product_uom_qty)"/></td>
                                            <td class="text-end fw-bold">
                                                <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": line.currency_id}'/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                                <t t-if="not grouped_sales">
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            <i class="fa fa-search me-2"></i>No sales found for the selected filters.
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script type="text/javascript">
            // <![CDATA[
            document.addEventListener('DOMContentLoaded', function () {
                var bluePalette = ['#00008B', '#1E90FF', '#4682B4', '#87CEEB', '#B0C4DE', '#6495ED'];

                // --- Monthly Trend (Line) ---
                var monthlyData = ]]> <t t-raw="monthly_chart_data"/> <![CDATA[;
                new Chart(document.getElementById('monthlyTrendChart').getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: monthlyData.labels,
                        datasets: [{
                            label: 'Units Sold',
                            data: monthlyData.data,
                            borderColor: '#00008B',
                            backgroundColor: 'rgba(0, 0, 139, 0.1)',
                            borderWidth: 2,
                            pointBackgroundColor: '#00008B',
                            fill: true,
                            tension: 0.4,
                        }]
                    },
                    options: {
    responsive: true,
    maintainAspectRatio: false, // Allows it to use the container height
    plugins: { legend: { display: false } },
    scales: { 
        x: { grid: { display: false } }, // Cleaner X axis
        y: { beginAtZero: true, grid: { color: '#f0f0f0' } } 
    }
}
                });

                // --- Sales by Customer (Doughnut) ---
                var customerData = ]]> <t t-raw="customer_chart_data"/> <![CDATA[;
                if (customerData.labels.length) {
                    customerData.datasets[0].backgroundColor = bluePalette;
                    new Chart(document.getElementById('customerPieChart').getContext('2d'), {
                        type: 'doughnut',
                        data: customerData,
                        options: {
                            responsive: true,
                            plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } }
                        }
                    });
                }

                // --- Top Products (Bar) ---
                var productData = ]]> <t t-raw="product_chart_data"/> <![CDATA[;
                new Chart(document.getElementById('topProductsChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: productData.labels,
                        datasets: [{
                            label: 'Units Sold',
                            data: productData.data,
                            backgroundColor: bluePalette,
                            borderRadius: 6,
                        }]
                    },
                    options: {
    indexAxis: 'y', // Switch to horizontal bars if names are long!
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
        x: { grid: { display: false } },
        y: { grid: { display: false } }
    }
}
                });

                // --- Expandable customer rows ---
                document.querySelectorAll('.customer-group-header').forEach(function (header) {
                    header.addEventListener('click', function () {
                        var target = this.getAttribute('data-target');
                        var rows = document.querySelectorAll('.' + target);
                        var icon = this.querySelector('.toggle-icon');
                        var isOpen = icon.style.transform === 'rotate(90deg)';
                        rows.forEach(function (row) {
                            row.style.display = isOpen ? 'none' : '';
                        });
                        icon.style.transform = isOpen ? '' : 'rotate(90deg)';
                    });
                });
            });
            // ]]>
            </script>
        </t>
    </template>



    <template id="vendor_support_page" name="Vendor Support">
        <t t-call="portal.portal_layout">
            <div id="wrap" class="container mt-4 mb-5">
                <div class="row align-items-center mb-4">
