<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="vendor_portal_navbar" inherit_id="portal.portal_layout">
        <xpath expr="//div[@id='wrap']" position="before">
            <nav class="navbar navbar-expand-lg shadow-sm sticky-top" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-bottom: 2px solid #6a1b9a;">
                <div class="container-fluid px-4">
                    <a class="navbar-brand fw-bold" href="/my/home" style="color: #6a1b9a;">
                        <i class="fa fa-th-large me-2"></i>Vendor Hub
                    </a>
                    <div class="collapse navbar-collapse" id="vendorNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item"><a class="nav-link fw-semibold" href="/my/home">Home</a></li>
                            <li class="nav-item"><a class="nav-link fw-semibold" href="/my/orders">Sales Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link fw-semibold" href="/my/tickets">Support</a></li>
                        </ul>
                    </div>
                </div>
            </nav>
        </xpath>
    </template>

    <template id="vendor_sales_history_page" name="Vendor Sales History">
        <t t-call="portal.portal_layout">
            <div class="container-fluid mt-3 mb-5">
                <div class="row mb-2">
                    <div class="col-12 d-flex justify-content-between align-items-end">
                        <div>
                            <h2 class="fw-bold" style="color: #6a1b9a;">Vendor Dashboard</h2>
                            <p class="text-muted mb-0">Manage your sales performance and inventory levels.</p>
                        </div>
                        <div class="text-end pb-1">
                            <span class="badge rounded-pill bg-light text-dark border shadow-sm" style="padding: 8px 15px;">
                                <i class="fa fa-clock-o me-1" style="color: #6a1b9a;"></i>
                                <span class="text-muted small fw-normal">Last Sync: </span>
                                <strong style="color: #6a1b9a;">
                                    <t t-esc="last_updated" t-options='{"widget": "datetime", "format": "HH:mm"}'/>
                                </strong>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="row mb-4 g-3 align-items-stretch">
                    <div class="col-md-9">
                        <div class="bg-light p-4 h-100 border d-flex align-items-center" style="border-radius: 12px;">
                            <form method="get" class="d-flex align-items-center w-100">
                                <label for="categ_id" class="me-3 fw-bold text-nowrap mb-0">Category Filter:</label>
                                <select name="categ_id" id="categ_id" class="form-select shadow-sm" onchange="this.form.submit()" style="max-width: 300px;">
                                    <option value="">All Categories</option>
                                    <t t-foreach="categories" t-as="cat">
                                        <option t-att-value="cat.id" t-att-selected="cat.id == current_categ_id">
                                            <t t-esc="cat.name"/>
                                        </option>
                                    </t>
                                </select>
                            </form>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 text-white h-100" style="background-color: #6a1b9a; border-radius: 12px;">
                            <div class="card-body d-flex flex-column justify-content-center text-center p-3">
                                <small class="text-uppercase opacity-75 fw-bold" style="font-size: 0.75rem;">Units Sold</small>
                                <h2 class="mb-0 fw-bold" style="font-size: 2.5rem;"><t t-esc="total_units_sold"/></h2>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-md-7">
                        <div class="card shadow-sm border-0 h-100" style="border-radius: 12px;">
                            <div class="card-header bg-white fw-bold border-0 pt-3">Inventory Status</div>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th>Category</th>
                                            <th class="text-end">On Hand</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="vendor_products" t-as="p">
                                            <tr>
                                                <td class="fw-bold"><t t-esc="p.name"/></td>
                                                <td class="text-muted small"><t t-esc="p.categ_id.name"/></td>
                                                <td class="text-end fw-bold">
                                                    <span t-attf-class="{{'text-danger' if p.qty_available &lt; 5 else 'text-primary'}}" t-esc="int(p.qty_available)"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-5">
                        <div class="card shadow-sm border-0 h-100" style="border-radius: 12px;">
                            <div class="card-header bg-white fw-bold border-0 pt-3">Monthly Sales</div>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Month</th>
                                            <th class="text-end">Units</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="monthly_sales" t-as="month">
                                            <tr>
                                                <td><t t-esc="month"/></td>
                                                <td class="text-end fw-bold text-success"><t t-esc="int(monthly_sales[month])"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0" style="border-radius: 12px;">
                    <div class="card-header bg-white fw-bold border-0 pt-3">Recent Sales History</div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 text-nowrap">
                            <thead class="bg-light text-muted small text-uppercase">
                                <tr>
                                    <th>Date</th>
                                    <th>Order #</th>
                                    <th>Customer</th>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="sales_history" t-as="line">
                                    <tr>
                                        <td><span t-field="line.create_date" t-options='{"widget": "date"}'/></td>
                                        <td><t t-esc="line.order_id.name"/></td>
                                        <td class="small"><t t-esc="line.order_id.partner_id.name"/></td> 
                                        <td class="fw-bold"><t t-esc="line.product_id.name"/></td>
                                        <td class="text-center"><t t-esc="int(line.product_uom_qty)"/></td>
                                        <td class="text-end fw-bold">
                                            <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": line.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_my_home_vendor_exclusive" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <div class="container mt-4 mb-2">
                <div class="card shadow-sm border-0 p-4 text-center" style="border-radius: 15px; background: #f8f9fa;">
                    <h4 class="fw-bold mb-3" style="color: #6a1b9a;">Vendor Portal</h4>
                    <p class="text-muted mb-4">Manage your performance and inventory status.</p>
                    <div>
                        <a href="/my/orders" class="btn text-white shadow" style="background-color: #6a1b9a !important; border-radius: 10px; padding: 15px 40px; font-size: 1.1rem;">
                            <i class="fa fa-line-chart me-2"></i><strong>Open Sales Dashboard</strong>
                        </a>
                    </div>
                </div>
            </div>
            <a href="/my/tickets" class="vendor-help-fab" title="Contact Support">
                <i class="fa fa-life-ring"></i><span class="ms-2">Support</span>
            </a>
            <style>
                .vendor-help-fab { position: fixed; bottom: 30px; left: 30px; color: #6a1b9a !important; border: 2px solid #6a1b9a; padding: 12px 25px; border-radius: 50px; display: flex; align-items: center; justify-content: center; text-decoration: none !important; z-index: 9999; transition: all 0.3s ease; font-weight: bold; backdrop-filter: blur(4px); }
                .o_portal_docs, .o_portal_my_home .row:not(.justify-content-center), #portal_client_category, [href="/my/invoices"], [href="/my/quotes"] { display: none !important; }
            </style>
        </xpath>
    </template>
</odoo>